<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Klaviyo" data-string="Klaviyo" name="fpg_odoo_klaviyo_key">
                    <block title="Authentication" name="odoo_klaviyo_authentication_setting_block">
                        <setting string="Production Private API Key">
                            <field name="production_api_key"/>
                        </setting>
                        <setting string="Test Private API Key">
                            <field name="test_api_key"/>
                        </setting>
                        <setting help="Activate to perform test. Desactivate for production.">
                            <field name="is_test"
                                widget="boolean_toggle"/>
                        </setting>
                        <div class="alert alert-info mt4" role="alert">
                            Connection tests will be performed based on the Private API Key selected.
                        </div>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
